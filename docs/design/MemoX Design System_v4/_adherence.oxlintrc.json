{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/memox-app/**",
              "ui_kits/memox-app/_features/account-sync/**",
              "ui_kits/memox-app/_features/account-sync/components/**",
              "ui_kits/memox-app/_features/dashboard/**",
              "ui_kits/memox-app/_features/dashboard/components/**",
              "ui_kits/memox-app/_features/deck-detail/**",
              "ui_kits/memox-app/_features/deck-detail/components/**",
              "ui_kits/memox-app/_features/drawer/**",
              "ui_kits/memox-app/_features/drawer/components/**",
              "ui_kits/memox-app/_features/export/**",
              "ui_kits/memox-app/_features/export/components/**",
              "ui_kits/memox-app/_features/flashcard-editor/**",
              "ui_kits/memox-app/_features/flashcard-editor/components/**",
              "ui_kits/memox-app/_features/match-mode/**",
              "ui_kits/memox-app/_features/match-mode/components/**",
              "ui_kits/memox-app/_features/guess-mode/**",
              "ui_kits/memox-app/_features/guess-mode/components/**",
