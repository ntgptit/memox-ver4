              "ui_kits/memox-app/_features/study-result/components/**",
              "ui_kits/memox-app/_features/study-session/**",
              "ui_kits/memox-app/_features/study-session/components/**",
              "ui_kits/memox-app/_features/theme/**",
              "ui_kits/memox-app/_features/theme/components/**",
              "ui_kits/memox-app/_shared/**"
