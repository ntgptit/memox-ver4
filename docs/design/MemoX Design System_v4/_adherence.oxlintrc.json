              "ui_kits/memox-app/_features/mode-picker/components/**",
              "ui_kits/memox-app/_features/recall-mode/**",
              "ui_kits/memox-app/_features/recall-mode/components/**",
              "ui_kits/memox-app/_features/fill-mode/**",
              "ui_kits/memox-app/_features/fill-mode/components/**",
              "ui_kits/memox-app/_features/import/**",
              "ui_kits/memox-app/_features/import/components/**",
              "ui_kits/memox-app/_features/library/**",
              "ui_kits/memox-app/_features/library/components/**",
              "ui_kits/memox-app/_features/player/**",
              "ui_kits/memox-app/_features/player/components/**",
              "ui_kits/memox-app/_features/reminder/**",
              "ui_kits/memox-app/_features/reminder/components/**",
              "ui_kits/memox-app/_features/review-mode/**",
              "ui_kits/memox-app/_features/review-mode/components/**",
